# square triangle #

:, &0, 10; # width and height stored into &0 #
:, &1, &0; # copy value of &0 to &1

           # outer loop #
-, &0, 1;  # subtract 1 from &0 #

           # inner loop #
-, &1, 1;  # subtract 1 from &1 #

!, 91;     # print [ #
!, 93;     # print ] #
~, &1, -3; # if &1 is not equal to 0, skip to inner loop #

!, 10;     # print new line #
~, &0, -7; # if &0 is not equal to 0, skip to outer loop #